PORT=3000

ESP32_DEFAULT_WS_URL=ws://192.168.4.1:81
ESP32_CONNECT_ON_START=false
ESP32_CONNECT_TIMEOUT_MS=8000
ROBOT_ESP32_GATEWAY_ALLOW_PUBLIC=false

LOCAL_BRAIN_ENABLED=true
LOCAL_BRAIN_PROVIDER=fireworks
LOCAL_BRAIN_MODEL=accounts/fireworks/models/gpt-oss-20b
LOCAL_BRAIN_REQUIRE_LOCAL_NETWORK=false
LOCAL_BRAIN_TIMEOUT_MS=20000
LOCAL_BRAIN_EVENT_TIMEOUT_MS=12000
LOCAL_BRAIN_AUTONOMOUS_TIMEOUT_MS=20000
LOCAL_BRAIN_TEMPERATURE=0.15
LOCAL_BRAIN_MAX_OUTPUT_TOKENS=192
LOCAL_BRAIN_TRACE=true

GEMINI_LIVE_ENABLED=true
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Kore
GEMINI_LIVE_THINKING_LEVEL=minimal
GEMINI_LIVE_ALLOW_PUBLIC_TOKEN=false

FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=
FIREWORKS_TOP_P=1
FIREWORKS_TOP_K=40
FIREWORKS_PRESENCE_PENALTY=0
FIREWORKS_FREQUENCY_PENALTY=0

SERVER_TRACE=true
SERVER_TRACE_POLL_ENDPOINTS=false
SERVER_TRACE_REQUEST_BODIES=true
SERVER_TRACE_RESPONSE_BODIES=true

LOOI_ATTENTION_WINDOW_MS=20000
LOOI_CONVERSATION_WINDOW_MS=30000
LOOI_SPEECH_GATE_EVENT_COOLDOWN_MS=800
LOOI_AUTONOMOUS_SCHEDULER_TICK_MS=1000
LOOI_IDLE_MICRO_MIN_MS=4000
LOOI_IDLE_MICRO_MAX_MS=12000
LOOI_MACRO_DEFAULT_RAMP_MS=160
