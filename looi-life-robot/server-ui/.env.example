PORT=3000
ESP32_DEFAULT_WS_URL=ws://192.168.4.1:81
ESP32_CONNECT_ON_START=true
ESP32_CONNECT_TIMEOUT_MS=8000
ROBOT_ESP32_GATEWAY_ALLOW_PUBLIC=false
ROBOT_BRIDGE_TOKEN=change_me_robot_bridge_token
ROBOT_BRIDGE_PUBLIC_URL=https://your-public-bridge-url.example
ROBOT_BRIDGE_ALLOW_UNAUTH_LOCAL=true
ROBOT_BRIDGE_ALLOW_UNAUTH_LAN=false
ROBOT_BRIDGE_REQUIRE_HTTPS_FOR_EXTERNAL=true
ROBOT_BRIDGE_POLL_MS=1000
ROBOT_REQUIRE_RUNTIME_AUTH=false
ROBOT_RUNTIME_PAIRING_CODE=change_me_runtime_pairing_code
ROBOT_RUNTIME_TOKEN_TTL_MS=86400000
ROBOT_RUNTIME_HEARTBEAT_STALE_MS=5000
ROBOT_ACTION_WAIT_TIMEOUT_MS=15000
ROBOT_EVENT_MAX_STORED=200
ROBOT_EVENT_WAIT_TIMEOUT_MS=30000
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6
KIMI_AGENT_POLL_MS=2500
KIMI_AGENT_EVENT_LIMIT=3
KIMI_AGENT_ACTION_WAIT_MS=15000
